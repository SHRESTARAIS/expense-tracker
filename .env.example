# ══════════════════════════════════════════════════════════════════════════════
# .env.example  –  Copy this to .env and fill in your values
# NEVER commit .env to version control
# ══════════════════════════════════════════════════════════════════════════════

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-super-secret-key-here

# ── Database URL ──────────────────────────────────────────────────────────────
# Local SQLite (default, no setup needed):
# DATABASE_URL=sqlite:///instance/expense_tracker.db

# Local MySQL:
# DATABASE_URL=mysql+pymysql://root:password@localhost/expense_db

# Cloud SQL (used in App Engine via Unix socket):
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@/DB_NAME?unix_socket=/cloudsql/PROJECT:REGION:INSTANCE

# ── Google Cloud Storage ──────────────────────────────────────────────────────
# Leave empty to use local file storage
GCS_BUCKET=your-bucket-name

# ── Google Cloud Project ──────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ── Upload folder (local dev) ─────────────────────────────────────────────────
UPLOAD_FOLDER=app/static/uploads
